package vista;

import javax.swing.SwingUtilities;

/**
 * Esta clase es la "tarea" de la animacion: recorre el tiempo de la
 * simulacion, tick por tick, y en cada uno pide que se actualice la
 * ventana. 
 *
 *   1. Esta clase implementa Runnable -> representa QUE se debe hacer.
 *   2. Un Thread la ejecuta en un hilo secundario -> QUIEN lo hace.
 *   3. Cada actualizacion visual se envia con SwingUtilities.invokeLater(),
 *      para que la modifique el hilo de Swing y no el hilo secundario.
 *
 */
  public class TareaSimulacion implements Runnable {

    private VentanaPrincipal ventana;
    private int tiempoTotal;
    private int milisegundosPorTick;
    
    // Si se pone en true, el ciclo se detiene en la siguiente vuelta.
    // Se usa cuando el usuario presiona "Reiniciar" a mitad de la animacion.
    private volatile boolean cancelada = false;

    public TareaSimulacion(VentanaPrincipal ventana, int tiempoTotal, int milisegundosPorTick) {
        this.ventana = ventana;
        this.tiempoTotal = tiempoTotal;
        this.milisegundosPorTick = milisegundosPorTick;
    }
    
    public void cancelar() {
        cancelada = true;
    }

    @Override
    public void run() {
        // ---- 1. Tarea lenta: recorrer el tiempo de la simulacion ----
        for (int t = 0; t <= tiempoTotal; t++) {
            if (cancelada) {
                return;
            }

            final int tiempoActual = t;

            // ---- 2. Actualizacion visual: se envia al hilo de Swing ----
            SwingUtilities.invokeLater(new Runnable() {
                @Override
                public void run() {
                    ventana.actualizarUnTick(tiempoActual);
                }
            });

            try {
                Thread.sleep(milisegundosPorTick);
            } catch (InterruptedException ex) {
                System.out.println("Simulacion interrumpida");
            }
        }
        if (cancelada) {
            return;
        }

        // ---- Aviso final, tambien enviado al hilo de Swing ----
        SwingUtilities.invokeLater(new Runnable() {
            @Override
            public void run() {
                ventana.finalizarSimulacion();
            }
        });
    }
}
